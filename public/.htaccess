# ============================================================
#  stratiumlegal.com — Apache (.htaccess)
#  Sitio estático Next.js (export) con next-intl (es/en/cn/in)
# ============================================================

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Raíz "/"  ->  "/es/"  (next-intl localePrefix: always)
  RewriteRule ^$ es/ [R=302,L]

  # API exportada sin extensión (archivos "editions" / "hero")
  RewriteRule ^api/dof/editions/$ api/dof/editions [L]
  RewriteRule ^api/dof/hero/$ api/dof/hero [L]
</IfModule>

# Index de cada carpeta (rutas con trailing slash)
DirectoryIndex index.html

# Página 404 personalizada
ErrorDocument 404 /404.html

# ============================================================
#  Caché de assets estáticos (hash inmutable de Next.js)
# ============================================================
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|eot|svg|png|jpe?g|gif|webp|avif|mp4|m4a|mp3|glb|gltf|bin|hdr|exr|ktx2|wasm)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# ============================================================
#  Compresión
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml \
    application/javascript application/json application/xml \
    image/svg+xml application/wasm font/ttf font/woff font/woff2
</IfModule>

# ============================================================
#  MIME types (por si el server no los trae por defecto)
# ============================================================
<IfModule mod_mime.c>
  AddType application/wasm            .wasm
  AddType model/gltf-binary          .glb
  AddType model/gltf+json            .gltf
  AddType image/svg+xml              .svg
  AddType application/manifest+json  .webmanifest
  AddType font/woff2                 .woff2
</IfModule>
